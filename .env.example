# Copy to .env.local and fill in. NEVER commit .env.local — it's gitignored.

# Venice AI key. Get one at https://venice.ai/settings/api
# Required: the TEE-hosted chat model API.
NEXT_PUBLIC_VENICE_API_KEY=

# Optional: which Venice model to start with. Defaults to e2ee-qwen3-30b-a3b-p.
# Only models with supportsFunctionCalling=true get native memory tools.
# All other e2ee models work via the marker-protocol compat layer.
NEXT_PUBLIC_VENICE_MODEL=e2ee-qwen3-30b-a3b-p
